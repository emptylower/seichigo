{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seichigo",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": [
    "nodejs_compat",
    "no_handle_cross_request_promise_resolution"
  ],
  "images": {
    "binding": "IMAGES"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  }
}
