# App
SITE_URL=http://localhost:3000

# Observability (Sentry + navigation probe)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_NAV_PROBE_SAMPLE_RATE=0.1
NEXT_PUBLIC_NAV_STALL_MS=1200
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Database (Postgres)
# For serverless environments (Vercel/Neon), use a pooled connection URL for DATABASE_URL.
# Neon pooler URLs contain '-pooler.' in the hostname (e.g., ep-xxx-pooler.region.aws.neon.tech).
# Connection pool is limited to 5 connections (suitable for Neon Nano tier).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Optional but recommended for Prisma migrations on Vercel/Neon (non-pooling direct connection)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

# Email provider (optional)
# Choose one of the following email configurations:
#
# Resend (recommended)
RESEND_API_KEY=
# EMAIL_FROM="SeichiGo <no-reply@your-verified-domain>"
#
# Email OTP (verification code)
# EMAIL_OTP_SECRET=change-me (optional; defaults to NEXTAUTH_SECRET)
# EMAIL_OTP_TTL_MINUTES=10
# EMAIL_OTP_COOLDOWN_SECONDS=60
#
# SMTP
EMAIL_SERVER=smtp://username:password@smtp.example.com:587
EMAIL_FROM="SeichiGo <no-reply@example.com>"

# or use explicit host options
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=username
# EMAIL_SERVER_PASSWORD=password

# Rate limiting
RATE_LIMIT_USER_PER_DAY=3
RATE_LIMIT_IP_PER_DAY=5
RATE_LIMIT_SALT=change-me

# Giscus (GitHub Discussions)
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Admin credentials login
ADMIN_EMAILS=
# Optional: override default admin password (default is 112233)
ADMIN_DEFAULT_PASSWORD=112233

# AI Assistant API (optional)
# If set, /api/ai/* endpoints also accept:
# - Authorization: Bearer <token>
# - X-AI-KEY: <token>
SEICHIGO_AI_API_KEY=

# SEO Spoke Factory (admin automation)
# Personal access token with repo + workflow permissions.
SEO_AUTOMATION_GITHUB_TOKEN=
# Target repository in owner/repo format.
SEO_AUTOMATION_REPO=
# GitHub workflow file used by admin run API.
SEO_AUTOMATION_WORKFLOW_FILE=seo-spoke-factory.yml
# Base branch for workflow dispatch.
SEO_AUTOMATION_BASE_BRANCH=main
# Feature flag: only enable generate in production after preview verification.
SEO_AUTOMATION_ENABLE_GENERATE=0
# GitHub Actions secret only: set 1/true to auto-enable PR auto-merge for generated PRs.
# SEO_AUTOMATION_AUTO_MERGE=0
# AI provider key used by SEO Spoke Factory candidate extraction/content generation.
GEMINI_API_KEY=
# Optional fallback: fetch published zh articles from AI API when workflow cannot access DB directly.
# Example: https://seichigo.com/api/ai
SEO_AUTOMATION_AI_API_BASE_URL=
# Token for AI API bearer auth (same value as SEICHIGO_AI_API_KEY on target server).
SEO_AUTOMATION_AI_API_KEY=
# Optional: base URL used by post-merge endpoint acceptance checks (default: https://seichigo.com).
SEO_AUTOMATION_SITE_URL=

# Daily Ops Report (Vercel logs)
# Vercel API token used for deployments/log fetch.
OPS_VERCEL_API_TOKEN=
# Optional: explicit Vercel project id (fallback: VERCEL_PROJECT_ID).
OPS_VERCEL_PROJECT_ID=
# Optional: Vercel team scope id for team-owned projects.
OPS_VERCEL_TEAM_ID=
# Shared secret for cron endpoint auth.
OPS_CRON_SECRET=
OPS_MAX_DEPLOYMENTS_PER_RUN=8
OPS_MAX_LOG_LINES_PER_RUN=20000
OPS_MAX_STORED_EVENTS_PER_RUN=2000
OPS_WARN_4XX_THRESHOLD=20
OPS_RETENTION_DAYS=90

# Anitabi map replica
# Feature flag for /map pages
FEATURE_MAP_REPLICA_ENABLED=1
# Optional: client key for in-page panorama embed (/map).
# If absent, panorama mode can still use Mapillary embed links when point source provides one.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional fallback key used by static map features; also accepted by panorama embed.
NEXT_PUBLIC_GOOGLE_MAPS_STATIC_API_KEY=
# Map preload v2 + vector map switches
NEXT_PUBLIC_MAP_PRELOAD_V2=1
NEXT_PUBLIC_MAP_VECTOR=1
# Vector provider order (left to right failover): maptiler,mapbox,stadia,raster
NEXT_PUBLIC_MAP_STYLE_PROVIDER_ORDER=maptiler,mapbox,stadia,raster
# Style failover timeout per provider attempt (ms)
NEXT_PUBLIC_MAP_STYLE_FAILOVER_TIMEOUT_MS=9000
# MapTiler vector style key (recommended for faster map rendering)
NEXT_PUBLIC_MAPTILER_KEY=
# Optional secondary providers for automatic fallback
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_STADIA_MAPS_API_KEY=
# Server-side key for Google Directions API (used by /api/me/routebooks/[id]/directions).
# Must have Directions API enabled. Falls back to GOOGLE_MAPS_API_KEY if unset.
GOOGLE_DIRECTIONS_API_KEY=
# Upstream API base (public API)
ANITABI_API_BASE_URL=https://api.anitabi.cn
# Upstream website base (icons/changelog/users.json)
ANITABI_SITE_BASE_URL=https://www.anitabi.cn
# Shared secret for /api/cron/anitabi/*
ANITABI_CRON_SECRET=
# Sync worker concurrency (1-8). Lower it for Neon/Vercel to avoid transaction contention.
ANITABI_SYNC_CONCURRENCY=2
# Optional cap for changed rows processed per run. Useful for Vercel Hobby limits.
# ANITABI_SYNC_MAX_ROWS_PER_RUN=300
# Optional soft time budget (ms) per run. Defaults to 7000 on Vercel and unlimited locally.
# ANITABI_SYNC_MAX_RUNTIME_MS=7000
# Hot tab external ranking window (days). Default: 90.
# ANITABI_HOT_WINDOW_DAYS=90
# Hot ranking cache TTL (minutes). Default: 360.
# ANITABI_HOT_CACHE_MINUTES=360
# AniList page count pulled per refresh (1-8). Default: 3 (50 entries per page).
# ANITABI_HOT_ANILIST_MAX_PAGES=3
# Enable auto enqueue for map translation tasks after successful sync (1=on, 0=off).
ANITABI_TRANSLATION_AUTO_ENQUEUE=0
# Optional raw snapshot dir override. On Vercel, /tmp is writable.
# ANITABI_RAW_DIR=/tmp/anitabi/raw
